#!/bin/sh
# Watchdog daemon for LTE QMI/MBIM connections on OpenWrt
# Monitors WAN connectivity and restarts the interface if disconnected
#
# Thanks to:
# "yosh781" "https://github.com/yosh781/Daemon-modem-watchdog_qmi-for-Openwrt"
# "@antonk" "https://forum.openwrt.org/t/create-a-sample-procd-init-script/230977"

# =========================================================
# GLOBAL CONFIGURATION
# =========================================================

# Log tag used by syslog (logger -t). Identifies all watchdog_mbim messages.
logheader="watchdog_mbim"

# Minimal system PATH to ensure required OpenWrt binaries are found.
PATH="/usr/sbin:/usr/bin:/sbin:/bin"

# Path to the persistent user configuration file (stored in flash).
CONFIG_FILE="/etc/watchdog_mbim.conf"

# =========================================================
# SINGLE INSTANCE LOCK (using atomic mkdir)
# =========================================================
lockdir="/tmp/lock/watchdog_mbim.lock"

mkdir -p /tmp/lock 2>/dev/null
if ! mkdir "$lockdir" 2>/dev/null; then
    logger -t "$logheader" "init: another instance is already running (lock dir: $lockdir)"
    exit 20
fi

# =========================================================
# CONFIG FILE HANDLING (flash -> RAM copy)
# =========================================================

# Configuration file check
if [ ! -f "$CONFIG_FILE" ]; then
        # If the original configuration file does not exist log and exit
        logger -t "$logheader" "init: configuration file $CONFIG_FILE missing, exiting"
        exit 1
else
        # Copy $CONFIG_FILE to /tmp/watchdog/mbim.conf atomically via mktemp + mv.
        # Copy is performed ONLY ON FIRST RUN (if the file does not already exist
        # in /tmp). Subsequent runs reuse the existing copy to preserve any
        # runtime modifications.
        if [ ! -f "/tmp/watchdog/mbim.conf" ]; then
                mkdir -p /tmp/watchdog 2>/dev/null || { logger -t "$logheader" "init: cannot create directory /tmp/watchdog"; exit 1; } 
                tmp_conf=$(mktemp /tmp/watchdog/mbim.conf.XXXXXX) || {
                        logger -t "$logheader" "init: mktemp failed for config copy"
                        exit 1
                }
                cp "$CONFIG_FILE" "$tmp_conf" || {
                        rm -f "$tmp_conf"
                        logger -t "$logheader" "init: cannot copy $CONFIG_FILE to $tmp_conf"
                        exit 1
                }
                mv "$tmp_conf" "/tmp/watchdog/mbim.conf" || {
                        rm -f "$tmp_conf"
                        logger -t "$logheader" "init: mv failed for config copy"
                        exit 1
                }
        fi

        # In all cases, use the temporary file as CONFIG_FILE
        # to allow runtime modifications without touching the original config
        CONFIG_FILE="/tmp/watchdog/mbim.conf"
fi

logger -t "$logheader" "init: using configuration file: $CONFIG_FILE"

# Load all variables from the copy configuration file
# SC1090 is disabled because the sourced file path is dynamic
# (resolved at runtime to /tmp/watchdog/mbim.conf)
#
# shellcheck disable=SC1090
. "$CONFIG_FILE"

# =========================================================
# DEFAULTS (safe fallback values)
# =========================================================

# Default syslog tag if not defined in configuration file.
logheader=${logheader:-"watchdog_mbim"}

# Network interface monitored by the watchdog.
iface=${iface:-"wan"}

# Runtime directory for temporary watchdog files (locks, flags, state).
watchdog_directory=${watchdog_directory:-/tmp/watchdog}

# Debug enable file. If present, additional verbose logging is activated.
watchdog_debug_file=${watchdog_debug_file:-/tmp/watchdog/mbim_debug}

# Global watchdog pause file. If present, main loop execution is skipped.
watchdog_block_file=${watchdog_block_file:-/tmp/watchdog/watchdog.block}

# Blocks external AT command execution during modem recovery.
# NOTE: only affects commands executed via "atcmd".
# WARNING: other tools (socat, picocom, direct AT access) are not blocked.
atcmd_block_file=${atcmd_block_file:-/tmp/watchdog/atcmd_block}

# Optional hooks executed during WAN state changes:
# - predown: before interface shutdown
# - postup: after interface recovery
# WARNING: user-defined scripts may interfere with network recovery logic.
watchdog_predown_file=${watchdog_predown_file:-/tmp/watchdog/predown.sh}
watchdog_postup_file=${watchdog_postup_file:-/tmp/watchdog/postup.sh}

# Loop timing
delay=${delay:-20}                       # Main loop interval in seconds.
delay_reconnect=${delay_reconnect:-120}  # Wait time after reconnection to allow network stabilization.

# Skip monitoring after boot (0 = no grace period, monitoring starts immediately)
# Recommended value: 600 (10 minutes) to allow modem registration time
boot_grace_period=${boot_grace_period:-600}

# Control device for QMI/MBIM modem communication.
modem_device=${modem_device:-"/dev/cdc-wdm0"}

# usbreset_id: USB Vendor ID and Product ID in hex format (VVVV:PPPP)
# Used by usbreset to identify the modem device on the USB bus.
# Default: 2c7c=Quectel, 0512=EC18 series
usbreset_id=${usbreset_id:-"2c7c:0512"}

# ping_targets: Space-separated list of IP addresses to ping.
# WAN is considered UP if at least one target responds.
# WAN is considered DOWN only if all targets fail.
ping_targets=${ping_targets:-"8.8.8.8 9.9.9.9 1.1.1.1"}

# Maximum time (seconds) allowed for connectivity recovery before failure.
ping_timeout_sec=${ping_timeout_sec:-300}

# Timeout used for post-reconnect verification phase.
ping_verify_timeout=${ping_verify_timeout:-60}

# Lock directory preventing multiple concurrent ping_logger instances.
ping_lock=${ping_lock:-/tmp/watchdog/ping_lock}

# =========================================================
# RUNTIME STATE VARIABLES
# =========================================================

# Runtime state flag indicating WAN disconnection event.
# WAN state flag: 0=connected, 1=disconnected
wan_disconnected=0

# ping_failed_flag_file: Internal event flag created by ping_logger() when
# connectivity remains unreachable for ping_timeout_sec seconds.
# Its only purpose is to signal the next main-loop iteration to perform
# escalation recovery (forced MBIM disconnect + safe_ifup + atcmd/usbreset).
# The flag is not intended to survive daemon restarts: it is removed during
# cleanup() to avoid triggering stale recovery actions after a restart.
# Lifecycle: created by ping_logger() -> consumed and removed by main loop
#            -> removed by cleanup() on daemon exit.
ping_failed_flag_file="$watchdog_directory/ping_failed"

# ping_force_fail_file: Manual test flag created by the operator to force
# ping_once() to always return failure, regardless of actual connectivity.
# Allows testing the full escalation ladder (safe_ifup -> umbim disconnect
# -> atcmd -C -> usbreset) without physically disconnecting the modem.
# The flag is NOT removed automatically during recovery: the operator must
# remove it manually when the test is complete.
# It IS removed during cleanup() to ensure test mode is cleared when the
# daemon stops or restarts, preventing stale forced failures on next start.
# See README "Simulated ping failure" for usage instructions.
ping_force_fail_file="$watchdog_directory/ping_once_force_fail"

# ping_force_fail_logged: Prevents duplicate log entries when ping_force_fail_file is present.
# Reset to 0 after test file removal. In-memory only, not persisted.
ping_force_fail_logged=0

# PID of background ping_logger process used for cleanup and monitoring.
ping_logger_pid=""

# Prevents atcmd -C from being called more than once per disconnect event.
# Reset to 0 when WAN comes back online (wan_disconnected returns to 0).
atcmd_cfun_done=0

# Last exit code from atcmd -C. Reset to empty string when WAN comes back online.
# Used by the usbreset escalation guard: empty string is treated as failure (:-1 fallback).
atcmd_rc=""

# Prevents usbreset from being called more than once per disconnect event.
# Reset to 0 when WAN comes back online (wan_disconnected returns to 0).
usbreset_done=0

# Uptime threshold after which monitoring starts (monotonic, immune to NTP).
# Calculated as start_uptime + boot_grace_period. 0 = monitoring starts immediately.
boot_grace_end_uptime=0

# wan4_device: Network device name for IPv4 WAN (e.g. wwan0)
# Empty string means no IPv4 WAN device detected yet
wan4_device=""

# Indicates whether IPv4 WAN interface is available and active.
wan4_available=0

# Last known WAN IP address before reconnect.
ip_previous=""

# Current WAN IP address after reconnect.
ip_current=""

# LOCK FILE / LOCKFILE_DATE for safe_ifup function
# LOCKFILE: Indicates if an ifup command is already running.
LOCKFILE="$watchdog_directory/ifup_lock"

# LOCKFILE_DATE: Contains the timestamp of when the lock was created.
# Used to detect stuck ifup processes older than N seconds.
LOCKFILE_DATE="$watchdog_directory/ifup_lock_date"

# =========================================================
# SIGNAL HANDLING AND CLEANUP
# =========================================================

# Cleanup child processes and runtime files
cleanup() {
        # Debug
        [ -f "$watchdog_debug_file" ] && logger -t "$logheader" "cleanup: terminating watchdog"

        # Remove atomic lock directory
        rmdir "$lockdir" 2>/dev/null

        # Terminate background ping_logger process if still running
        if [ -n "$ping_logger_pid" ]; then
            kill "$ping_logger_pid" 2>/dev/null
            wait "$ping_logger_pid" 2>/dev/null
        fi

        # Force-remove ping_lock in case ping_logger was killed before its own rmdir.
        # ping_logger also has an internal trap for TERM/INT, but this acts as safety net
        # (e.g. SIGKILL or subshell trap failure).
        [ -n "$ping_lock" ] && rmdir "$ping_lock" 2>/dev/null

        # Remove runtime files
        [ -n "$atcmd_block_file" ]      && rm -f "$atcmd_block_file"
        [ -n "$LOCKFILE" ]              && rm -f "$LOCKFILE"
        [ -n "$LOCKFILE_DATE" ]         && rm -f "$LOCKFILE_DATE"
        [ -n "$ping_failed_flag_file" ] && rm -f "$ping_failed_flag_file"
        [ -n "$ping_force_fail_file" ]  && rm -f "$ping_force_fail_file"

        # exit 0 is required to terminate the process immediately after cleanup.
        # Without it, after SIGTERM the shell returns to the interrupted sleep()
        # and the process remains alive until procd sends SIGKILL (term_timeout).
        # This causes "not stopped on SIGTERM, sending SIGKILL instead" in syslog.
        exit 0
}

# SIGTERM / SIGINT: terminate daemon and cleanup runtime files.
# EXIT is intentionally excluded: in ash/busybox EXIT trap behaviour is
# inconsistent - it can fire on function returns (not just process exits),
# which would remove valid lock files during normal subshell operations.
trap cleanup TERM INT

# =========================================================
# DEPENDENCIES
# =========================================================

# Ensure watchdog directory exists
mkdir -p "$watchdog_directory" 2>/dev/null || { logger -t "$logheader" "init: cannot create directory $watchdog_directory"; exit 1; }

REQUIRED_BINS="uqmi umbim timeout jsonfilter"
missing=""

for bin in $REQUIRED_BINS; do
        if ! command -v "$bin" >/dev/null 2>&1; then
                missing="$missing $bin"
        fi
done

if [ -n "$missing" ]; then
        logger -t "$logheader" "init: missing required binaries:$missing, watchdog not started"
        exit 1
fi

# Optional binary: atcmd (/root/bin/atcmd)
# Used for CFUN modem restart before escalating to usbreset.
# Not required - if absent, CFUN escalation is silently skipped.
if [ -x /root/bin/atcmd ]; then
        logger -t "$logheader" "init: atcmd available (/root/bin/atcmd), CFUN escalation enabled"
else
        logger -t "$logheader" "init: atcmd not found, CFUN escalation disabled"
fi

# Optional binary: usbreset (/usr/bin/usbreset)
# Used as last-resort USB modem reset when atcmd -C fails or is not available.
# Not required - if absent, USB reset escalation is silently skipped.
if [ -x /usr/bin/usbreset ]; then
        logger -t "$logheader" "init: usbreset available (/usr/bin/usbreset), USB reset escalation enabled"
else
        logger -t "$logheader" "init: usbreset not found, USB reset escalation disabled"
fi

# =========================================================
# CONFLICT CHECKS
# =========================================================

# ModemManager conflicts with uqmi/umbim by competing for modem control.
# If ModemManager is installed, abort regardless of interface protocol.
# Skip this check if /tmp/watchdog/skip_check_modemmanager exists.
# Useful for testing on systems where ModemManager is installed but not active.
if [ ! -f "$watchdog_directory/skip_check_modemmanager" ]; then
        if pidof ModemManager >/dev/null 2>&1; then
                logger -t "$logheader" "init: ModemManager is running, conflicts with uqmi/umbim, exiting"
                exit 1
        fi
else
        logger -t "$logheader" "init: ModemManager check skipped ($watchdog_directory/skip_check_modemmanager exists)"
fi

if ! ubus call network.interface."$iface" status >/dev/null 2>&1; then
        logger -t "$logheader" "init: WAN interface not found"
        exit 1
fi

# =========================================================
# FUNCTIONS
# =========================================================

# Emit a fatal configuration error to syslog and stderr, then exit.
# Called only during startup (before the main loop) when a configuration
# value is invalid. Using exit (not return) is intentional: a misconfigured
# daemon must not start.
fatal() {
        logger -t "$logheader" "config error: $*"
        echo "config error: $*" >&2
        exit 1
}

# Return 0 if $1 is a non-empty string of digits only (unsigned integer).
# Return 1 for empty string or any non-digit character.
# Used by validate_config to guard variables that are later used in
# arithmetic expressions, where a non-numeric value causes a syntax error
# in ash rather than a safe fallback.
is_uint() {
        case "$1" in
                ''|*[!0-9]*) return 1 ;;
                *)            return 0 ;;
        esac
}

# Validate critical configuration variables after sourcing the config file
# and applying defaults. Fails fast with a clear syslog message if any
# value would cause arithmetic errors or illogical behaviour at runtime.
# Only variables used in arithmetic or with hard semantic constraints are
# checked; path and string variables are left to the operator.
validate_config() {
        # Numeric checks: these variables are used in arithmetic expressions
        # in the main loop and functions. A non-numeric value in ash causes
        # a syntax error instead of a safe fallback.
        is_uint "$boot_grace_period"  || fatal "boot_grace_period must be a non-negative integer (got: '$boot_grace_period')"
        is_uint "$delay"              || fatal "delay must be a non-negative integer (got: '$delay')"
        is_uint "$delay_reconnect"    || fatal "delay_reconnect must be a non-negative integer (got: '$delay_reconnect')"
        is_uint "$ping_timeout_sec"   || fatal "ping_timeout_sec must be a non-negative integer (got: '$ping_timeout_sec')"
        is_uint "$ping_verify_timeout" || fatal "ping_verify_timeout must be a non-negative integer (got: '$ping_verify_timeout')"

        # Range checks: zero values would cause infinite loops or divide-by-zero
        # in sleep and timeout expressions.
        [ "$delay" -gt 0 ]              || fatal "delay must be > 0 (got: '$delay')"
        [ "$delay_reconnect" -gt 0 ]    || fatal "delay_reconnect must be > 0 (got: '$delay_reconnect')"
        [ "$ping_timeout_sec" -gt 0 ]   || fatal "ping_timeout_sec must be > 0 (got: '$ping_timeout_sec')"
        [ "$ping_verify_timeout" -gt 0 ] || fatal "ping_verify_timeout must be > 0 (got: '$ping_verify_timeout')"

        # Semantic constraint: ping_verify_timeout is a subset of ping_timeout_sec.
        # If ping_verify_timeout > ping_timeout_sec, ping_verify() would never
        # trigger escalation because ping_logger would timeout first.
        [ "$ping_verify_timeout" -le "$ping_timeout_sec" ] \
                || fatal "ping_verify_timeout ($ping_verify_timeout) must be <= ping_timeout_sec ($ping_timeout_sec)"

        # modem_device must be a /dev/ path. Does not check existence here
        # because the device may not be present until the modem enumerates.
        case "$modem_device" in
                /dev/*) ;;
                *) fatal "modem_device must start with /dev/ (got: '$modem_device')" ;;
        esac

        # usbreset_id must be in VVVV:PPPP hex format (4 hex digits, colon, 4 hex digits).
        # Pattern must be on a single line in ash - multi-line case patterns are not supported.
        case "$usbreset_id" in
                [0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f]:[0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f]) ;;
                *) fatal "usbreset_id must be in VVVV:PPPP hex format (got: '$usbreset_id')" ;;
        esac

        # ping_targets must not be empty: an empty list would make ping_once()
        # always return 0 (no targets to fail), masking real connectivity loss.
        [ -n "$ping_targets" ] || fatal "ping_targets must not be empty"

        logger -t "$logheader" "init: configuration validated successfully"
}

# Read system uptime in whole seconds from /proc/uptime.
# Uses only the monotonic uptime counter - immune to NTP adjustments.
# Returns empty string on read failure (e.g. /proc/uptime inaccessible).
# Caller MUST handle the empty string case.
get_uptime_sec() {
        read -r up _ < /proc/uptime 2>/dev/null
        up="${up%.*}"
        [ -n "$up" ] && echo "$up"
}

# Get current WAN IP address
# Requires ${iface}_4 dynamic interface created by MBIM/QMI
# wan4_available must be 1 for this function to execute
get_wan_ip() {
        [ "$wan4_available" -eq 0 ] && return
        ubus call network.interface."$iface"_4 status 2>/dev/null | jsonfilter -e "@['ipv4-address'][0].address"
}

# Try each target in ping_targets in sequence.
# Returns 0 as soon as one target responds, 1 if all fail.
# If wan4_device is known, binds ping to that interface to avoid
# false positives on multi-WAN systems.
# Used by both ping_logger (background) and ping_verify (synchronous).
ping_once() {
        # Test mode: force ping failure.
        # Useful for validating escalation paths without modifying
        # ping_targets, routing tables, firewall rules or WAN state.
        if [ -f "$ping_force_fail_file" ]; then
                if [ "$ping_force_fail_logged" -eq 0 ]; then
                        logger -t "$logheader" "ping_once: TEST MODE active, forcing ping failure"
                        ping_force_fail_logged=1
                fi
                return 1
        fi
        ping_force_fail_logged=0

        for pt in $ping_targets; do
                if [ -n "$wan4_device" ]; then
                        ping -I "$wan4_device" -c 1 -W 1 "$pt" >/dev/null 2>&1
                else
                        ping -c 1 -W 1 "$pt" >/dev/null 2>&1
                fi
                ping_once_rc=$?
                if [ "$ping_once_rc" -eq 0 ]; then
                        [ -f "$watchdog_debug_file" ] && logger -t "$logheader" "ping_once: ok (target=$pt device=${wan4_device:-(none)})"
                        return 0
                fi
        done
        return 1
}

# Background connectivity monitor - runs after safe_ifup to log when WAN recovers.
# Does not make recovery decisions: its only purpose is to wait for the first
# successful ping and log how long the reconnect took.
# Sets ping_failed_flag_file if ping_timeout_sec elapses without any response,
# signalling the main loop to escalate on the next iteration.
# Uses atomic mkdir lock to prevent multiple concurrent instances.
ping_logger() {
        # Atomic lock via mkdir
        mkdir "$ping_lock" 2>/dev/null || return

        # Internal trap: releases the lock if this subshell receives TERM or INT.
        # EXIT trap is intentionally omitted: in ash/busybox, EXIT can fire on
        # function returns (not just subshell exits), which would remove the lock
        # prematurely. TERM/INT are sufficient; cleanup() in the parent also
        # calls rmdir as a safety net for SIGKILL or subshell trap failure.
        # kill 0 is intentionally omitted: ping_logger runs as a background
        # subshell child of the daemon. Sending SIGKILL to process group 0 would
        # propagate to the parent daemon, causing unintended termination.
        trap '
            rmdir "$ping_lock" 2>/dev/null
            exit 0
        ' INT TERM

        rm -f "$ping_failed_flag_file"

        ping_start_uptime=$(get_uptime_sec)

        # Debug
        [ -f "$watchdog_debug_file" ] && logger -t "$logheader" "ping_logger: started (timeout=${ping_timeout_sec}s targets=[$ping_targets] device=${wan4_device:-(none)})"

        while :; do

                if ping_once; then
                        now_uptime=$(get_uptime_sec)
                        delta=$(( ${now_uptime:-0} - ${ping_start_uptime:-0} ))
                        logger -t "$logheader" "ping_logger: WAN reachable after ${delta}s"
                        rmdir "$ping_lock" 2>/dev/null
                        trap - INT TERM
                        return
                fi

                # Check if global ping timeout has been exceeded.
                now_uptime=$(get_uptime_sec)
                if [ $(( ${now_uptime:-0} - ${ping_start_uptime:-0} )) -ge "$ping_timeout_sec" ]; then
                        logger -t "$logheader" "ping_logger: timeout after ${ping_timeout_sec}s, setting ping_failed_flag"
                        touch "$ping_failed_flag_file"
                        rmdir "$ping_lock" 2>/dev/null
                        trap - INT TERM
                        return
                fi

                sleep 1
        done
}

# Synchronous connectivity gate for escalation recovery.
# Called after the second safe_ifup (forced MBIM disconnect path) to decide
# whether to proceed with the normal recovery or escalate to atcmd -C / usbreset.
# Polls ping_once for up to ping_verify_timeout seconds.
# Returns 0 (connectivity restored, no escalation needed) or
#         1 (still unreachable, caller should escalate).
ping_verify() {
        pv_timeout=${ping_verify_timeout:-60}
        pv_start=$(get_uptime_sec)

        logger -t "$logheader" "ping_verify: started (max ${pv_timeout}s targets=[$ping_targets] device=${wan4_device:-(none)})"

        while :; do
                if ping_once; then
                        pv_now=$(get_uptime_sec)
                        pv_delta=$(( ${pv_now:-0} - ${pv_start:-0} ))
                        logger -t "$logheader" "ping_verify: WAN reachable after ${pv_delta}s"
                        return 0
                fi

                pv_now=$(get_uptime_sec)
                if [ $(( ${pv_now:-0} - ${pv_start:-0} )) -ge "$pv_timeout" ]; then
                        logger -t "$logheader" "ping_verify: timeout after ${pv_timeout}s, connectivity not restored"
                        return 1
                fi

                sleep 1
        done
}

# Check MBIM/QMI connection status (other protocols treated as disconnected)
get_lte_status() {
        lte_status_start_ts=$(get_uptime_sec)

        max_retries=4       # Maximum number of retries
        timeout_sec=4       # Timeout for each uqmi call (seconds)
        sleep_between=1     # Sleep between retries (seconds)
        attempt=1
        lte_rc=1            # Return code of modem status command.
        lte_status=""       # Raw output from uqmi/umbim status query.

        while [ $attempt -le $max_retries ]; do
                if [ "$lteproto" = "mbim" ]; then
                        # Query MBIM modem status with timeout
                        lte_status=$(timeout "$timeout_sec" uqmi -m -d "$modem_device" --get-data-status 2>&1)
                        lte_rc=$?
                elif [ "$lteproto" = "qmi" ]; then
                        # Query QMI modem status with timeout
                        lte_status=$(timeout "$timeout_sec" uqmi -d "$modem_device" --get-data-status 2>&1)
                        lte_rc=$?
                else
                        # WAN is not MBIM/QMI, treat as disconnected
                        lte_status=""
                        lte_rc=1
                        break
                fi

                # If uqmi succeeded, break the retry loop
                if [ "$lte_rc" -eq 0 ]; then
                        # Command succeeded, modem responded
                        break
                elif [ "$lte_rc" -eq 124 ]; then
                        # Timeout occurred, increment attempt and retry
                        attempt=$((attempt + 1))
                        [ $attempt -le $max_retries ] && sleep "$sleep_between"
                else
                        # Other serious error, exit retry loop
                        break
                fi
        done

        lte_status_end_ts=$(get_uptime_sec)

        # Guard against empty uptime reads (get_uptime_sec returns empty string
        # on /proc/uptime failure). Arithmetic on empty variables causes a syntax
        # error in ash; default both to 0 if unset.
        if [ -n "$lte_status_end_ts" ] && [ -n "$lte_status_start_ts" ]; then
                lte_status_delta=$((lte_status_end_ts - lte_status_start_ts))
        else
                lte_status_delta=0
        fi

        # Parsed connectivity state (1 = connected, 0 = disconnected).
        if [ -n "$lte_status" ]; then
                lte_connected=$(echo "$lte_status" | grep -c "\"connected\"")
        else
                lte_connected=0
        fi

        # Logging
        if [ "$lte_connected" -eq 0 ] || [ "$lte_rc" -ne 0 ]; then
                logger -t "$logheader" -- "get_lte_status: lte_status=$lte_status lte_rc=$lte_rc lte_connected=$lte_connected"
                [ -f "$watchdog_debug_file" ] && logger -t "$logheader" "get_lte_status: delta=${lte_status_delta}s attempt=${attempt}"
        fi
}

# Safely restarts the interface via ubus, preventing concurrent executions
safe_ifup() {
        # Save start timestamp
        safe_ifup_start_ts=$(get_uptime_sec)

        # Debug
        [ -f "$watchdog_debug_file" ] && logger -t "$logheader" "safe_ifup: invoked (pid=$$)"

        # Stale lock detection: check if the PID stored in the lock file is still
        # alive and belongs to this daemon.
        # NOTE: there is a narrow race window between reading the PID and calling
        # kill -0 / reading cmdline: the original process could exit and a new
        # unrelated process could reuse the same PID in that interval. This is
        # considered acceptable in practice given the system's low process churn,
        # but callers should be aware this check is best-effort, not atomic.
        if [ -f "$LOCKFILE" ]; then
                read -r lock_pid < "$LOCKFILE" 2>/dev/null
                if ! kill -0 "$lock_pid" 2>/dev/null; then
                        logger -t "$logheader" "safe_ifup: stale lock detected (dead pid=$lock_pid), removing"
                        rm -f "$LOCKFILE" "$LOCKFILE_DATE"
                else
                        lock_cmdline=$(cat /proc/"$lock_pid"/cmdline 2>/dev/null | tr '\0' ' ')
                        case "$lock_cmdline" in
                                *watchdog_mbim*) ;; # owner is watchdog_mbim, lock is valid
                                *) logger -t "$logheader" "safe_ifup: stale lock detected (pid=$lock_pid is not watchdog_mbim: $lock_cmdline), removing"
                                   rm -f "$LOCKFILE" "$LOCKFILE_DATE" ;;
                        esac
                fi
        fi

        # Remove stale lock if older than 300 seconds.
        # This protects against cases where the previous process crashed
        # without releasing the lock.
        if [ -f "$LOCKFILE_DATE" ]; then
                read -r lock_ts < "$LOCKFILE_DATE" 2>/dev/null
                now_ts=$(get_uptime_sec)
                if [ -n "$lock_ts" ] && [ -n "$now_ts" ] && [ $((now_ts - lock_ts)) -gt 300 ]; then
                        logger -t "$logheader" "safe_ifup: stale lock too old ($((now_ts - lock_ts))s), removing"
                        rm -f "$LOCKFILE" "$LOCKFILE_DATE"
                fi
        fi

        # lock exists, skip
        if [ -f "$LOCKFILE" ]; then
                logger -t "$logheader" "safe_ifup: another ifup already running, skipping"
                return
        fi

        # Create lock file and store current PID
        echo $$ > "$LOCKFILE"

        # Create lock file and store current uptime (monotonic - immune to NTP).
        get_uptime_sec > "$LOCKFILE_DATE"

        # Debug
        [ -f "$watchdog_debug_file" ] && logger -t "$logheader" "safe_ifup: lock acquired"

        # check pending state
        pending=$(ubus call network.interface."$iface" status 2>/dev/null | grep '"pending": true')
        if [ -n "$pending" ]; then
                logger -t "$logheader" "safe_ifup: interface $iface is pending, aborting"
                rm -f "$LOCKFILE" "$LOCKFILE_DATE"
                return
        fi

        # Debug
        [ -f "$watchdog_debug_file" ] && logger -t "$logheader" "safe_ifup: bringing $iface down"

        # ubus call network.interface.$iface down
        timeout --preserve-status -k 2 10 ubus call network.interface."$iface" down >/dev/null 2>&1
        rc=$?

        # Logging
        if [ "$rc" -eq 124 ]; then
                logger -t "$logheader" "safe_ifup: $iface down timed out"
        elif [ "$rc" -ne 0 ]; then
                logger -t "$logheader" "safe_ifup: $iface down failed (exit=$rc)"
        fi

        # Micro sleep
        [ -f "$watchdog_debug_file" ] && logger -t "$logheader" "safe_ifup: sleep 2"
        sleep 2

        # Debug
        [ -f "$watchdog_debug_file" ] && logger -t "$logheader" "safe_ifup: bringing $iface up"

        # ubus call network.interface.$iface up
        timeout --preserve-status -k 2 10 ubus call network.interface."$iface" up >/dev/null 2>&1
        rc=$?

        # Logging
        if [ "$rc" -eq 124 ]; then
                logger -t "$logheader" "safe_ifup: $iface up timed out"
        elif [ "$rc" -ne 0 ]; then
                logger -t "$logheader" "safe_ifup: $iface up failed (exit=$rc)"
        else
                logger -t "$logheader" "safe_ifup: $iface up succeeded"
        fi

        safe_ifup_end_ts=$(get_uptime_sec)

        # Guard against empty uptime reads (same as lte_status_delta above).
        if [ -n "$safe_ifup_end_ts" ] && [ -n "$safe_ifup_start_ts" ]; then
                safe_ifup_duration=$((safe_ifup_end_ts - safe_ifup_start_ts))
        else
                safe_ifup_duration=0
        fi

        # Debug
        [ -f "$watchdog_debug_file" ] && logger -t "$logheader" "safe_ifup: finished safe_ifup_duration=${safe_ifup_duration}s"

        # remove lock files
        rm -f "$LOCKFILE" "$LOCKFILE_DATE"

        # Debug
        [ -f "$watchdog_debug_file" ] && logger -t "$logheader" "safe_ifup: lock released"
}

# =========================================================
# CONFIG VALIDATION
# =========================================================

# Validate configuration values after sourcing the config file and applying
# defaults. Called here so that all helper functions (fatal, is_uint) are
# already defined. Exits with code 1 on the first invalid value found.
validate_config

# =========================================================
# START DAEMON (Runs when the daemon starts - only 1 time)
# =========================================================

# Check WAN protocol and exit if it is not MBIM or QMI
# WAN protocol type read from UCI.
# Only "mbim" and "qmi" are supported by this watchdog.
lteproto=$(uci -q get network."$iface".proto 2>/dev/null)
if [ "$lteproto" != "mbim" ] && [ "$lteproto" != "qmi" ]; then
       logger -t "$logheader" "main: WAN interface is not using mbim or qmi"
       exit 1
fi

# Check if dynamic interface ${iface}_4 exists (created by MBIM/QMI for IP assignment)
# If found, retrieve the physical device for ping binding and IP tracking
if ubus call network.interface."$iface"_4 status >/dev/null 2>&1; then
        wan4_available=1
        wan4_device=$(ubus call network.interface."$iface"_4 status 2>/dev/null | jsonfilter -e '@.device')
        logger -t "$logheader" "main: ${iface}_4 found, IP tracking enabled"
else
        wan4_available=0
        wan4_device=""
        logger -t "$logheader" "main: ${iface}_4 not found, IP tracking disabled"
fi

# Calculate boot grace period end using monotonic uptime (immune to NTP adjustments).
# /proc/uptime is read once at daemon start; the resulting threshold is compared
# against uptime (not wall clock) in every loop iteration.
#
# Grace period is active ONLY when the daemon starts near boot (uptime < boot_grace_period).
# On manual restart or procd respawn (uptime >= boot_grace_period), the grace period is
# skipped entirely so the daemon begins monitoring immediately.
#
# NOTE: the [ "$start_uptime" -ge 0 ] 2>/dev/null guard intentionally suppresses
# the arithmetic error when start_uptime is empty (get_uptime_sec returned nothing).
# In that case the condition evaluates to false, boot_grace_period is set to 0,
# and the grace period is disabled - a safe fallback.
if [ "$boot_grace_period" -gt 0 ]; then
        start_uptime=$(get_uptime_sec)
        if [ -n "$start_uptime" ] && [ "$start_uptime" -ge 0 ] 2>/dev/null; then
                if [ "$start_uptime" -lt "$boot_grace_period" ]; then
                        # Uptime is still within the grace window: daemon started near boot.
                        # Delay monitoring to avoid interfering with WAN initialization.
                        boot_grace_end_uptime=$((start_uptime + boot_grace_period))
                        logger -t "$logheader" "init: grace period active, ends at uptime=${boot_grace_end_uptime}s (boot_grace_period=${boot_grace_period}s)"
                else
                        # Uptime already exceeds grace period: manual or procd restart.
                        # Skip grace period and begin monitoring immediately.
                        logger -t "$logheader" "init: uptime=${start_uptime}s >= boot_grace_period=${boot_grace_period}s, grace period skipped"
                fi
        else
                logger -t "$logheader" "init: /proc/uptime unreadable, disabling grace period"
                boot_grace_period=0
        fi
fi

# =========================================================
# MAIN LOOP
# =========================================================

# Loop iteration counter used for diagnostics and monitoring stability.
count=0

# Loop
while true; do
        count=$((count+1))

        # Overflow guard: reset counter to avoid arithmetic issues on very long uptimes.
        [ "$count" -gt 1000000 ] && count=0

        # Check if watchdog_block_file exists; if yes, skip this iteration
        if [ -f "$watchdog_block_file" ]; then
                logger -t "$logheader" "main: watchdog_block_file exists ($watchdog_block_file), skipping iteration"
                sleep "$delay"
                continue
        fi

        # Boot grace period: skip iterations until grace period has elapsed.
        # Comparison uses monotonic uptime - immune to NTP clock jumps.
        # Protects against false recovery during WAN initialization after boot.
        # Useful when watchdog is started at boot without rc.local delay.
        # Set boot_grace_period=0 in watchdog_mbim.conf to disable.
        if [ "$boot_grace_period" -gt 0 ] && [ "$boot_grace_end_uptime" -gt 0 ]; then
                now_uptime=$(get_uptime_sec)
                if [ -n "$now_uptime" ] && [ "$now_uptime" -lt "$boot_grace_end_uptime" ]; then
                        [ -f "$watchdog_debug_file" ] && logger -t "$logheader" \
                                "main: boot grace period active (uptime=${now_uptime}s < end=${boot_grace_end_uptime}s)"
                        sleep "$delay"
                        continue
                fi
        fi

        # Check ModemManager conflict at runtime.
        # Skip this check if /tmp/watchdog/skip_check_modemmanager exists.
        # Useful for testing on systems where ModemManager is installed but not active.
        if [ ! -f "$watchdog_directory/skip_check_modemmanager" ]; then
                if pidof ModemManager >/dev/null 2>&1; then
                        logger -t "$logheader" "main: ModemManager is running, skipping iteration"
                        sleep "$delay"
                        continue
                fi
        else
                [ -f "$watchdog_debug_file" ] && logger -t "$logheader" "main: ModemManager check skipped ($watchdog_directory/skip_check_modemmanager exists)"
        fi

        # Forced MBIM disconnect if ping timeout detected
        if [ -f "$ping_failed_flag_file" ]; then
                rm -f "$ping_failed_flag_file"

                if [ "$lteproto" = "mbim" ]; then
                        logger -t "$logheader" "main: ping timeout detected -> forcing MBIM disconnect"

                        # disconnect MBIM modem with timeout (TERM after 5s, KILL after 2s)
                        timeout --preserve-status -k 2 5 umbim -d "$modem_device" disconnect >/dev/null 2>&1
                        rc=$?

                        if [ "$rc" -eq 124 ]; then
                                logger -t "$logheader" "main: umbim disconnect timed out after 5s"
                        elif [ "$rc" -ne 0 ]; then
                                logger -t "$logheader" "main: umbim disconnect failed with exit code $rc"
                        else
                                logger -t "$logheader" "main: umbim disconnect succeeded"
                        fi

                        # Micro sleep
                        sleep 3

                        # Second attempt: safe_ifup after forced MBIM disconnect
                        safe_ifup

                        # Verify connectivity after second safe_ifup before escalating.
                        # ping_verify polls ping_once (multi-target) for up to
                        # ping_verify_timeout seconds (default 60s).
                        # Returns 0 if any target responds (no escalation needed),
                        # or 1 if the timeout expires (proceed with escalation).
                        if ping_verify; then
                                # Connectivity restored after second safe_ifup - no escalation needed
                                logger -t "$logheader" "main: WAN restored after second safe_ifup"
                                sleep "$delay_reconnect"
                        else
                                # Connectivity still down after second safe_ifup.
                                # Escalate to atcmd -C (CFUN modem restart) if available
                                # and not already invoked for this disconnect event.
                                logger -t "$logheader" "main: WAN still down after second safe_ifup"
                                if [ -x /root/bin/atcmd ] && [ "$atcmd_cfun_done" -eq 0 ]; then
                                        logger -t "$logheader" "main: invoking atcmd -C (CFUN modem restart)"
                                        /root/bin/atcmd --internal-watchdog -C
                                        atcmd_rc=$?
                                        atcmd_cfun_done=1
                                        if [ "$atcmd_rc" -eq 0 ]; then
                                                logger -t "$logheader" "main: atcmd -C completed successfully (rc=$atcmd_rc)"
                                        elif [ "$atcmd_rc" -eq 11 ]; then
                                                logger -t "$logheader" "main: atcmd -C daily limit reached, skipping CFUN escalation"
                                        else
                                                logger -t "$logheader" "main: atcmd -C failed (rc=$atcmd_rc), resuming loop"
                                        fi
                                elif [ "$atcmd_cfun_done" -eq 1 ]; then
                                        [ -f "$watchdog_debug_file" ] && logger -t "$logheader" "main: atcmd -C already invoked for this disconnect event, skipping"
                                else
                                        [ -f "$watchdog_debug_file" ] && logger -t "$logheader" "main: /root/bin/atcmd not available, skipping CFUN escalation"
                                fi

                                # Escalate to usbreset if atcmd -C failed or is not available
                                # and usbreset has not already been invoked for this disconnect event.
                                # usbreset resets the USB device at hardware level - netifd will
                                # automatically re-initialize the modem and restore the connection
                                # without requiring safe_ifup.
                                # Limited to one invocation per disconnect event to prevent loops.
                                if [ -x /usr/bin/usbreset ] && [ "$usbreset_done" -eq 0 ]; then
                                        if [ "$atcmd_cfun_done" -eq 0 ] || [ "${atcmd_rc:-1}" -ne 0 ]; then
                                                logger -t "$logheader" "main: invoking usbreset $usbreset_id (USB modem reset)"
                                                /usr/bin/usbreset "$usbreset_id"
                                                usbreset_rc=$?
                                                usbreset_done=1
                                                if [ "$usbreset_rc" -eq 0 ]; then
                                                        logger -t "$logheader" "main: usbreset completed successfully (rc=$usbreset_rc)"
                                                else
                                                        logger -t "$logheader" "main: usbreset failed (rc=$usbreset_rc), resuming loop"
                                                fi
                                                # netifd handles modem re-initialization automatically after USB reset.
                                                # Wait to allow USB re-enumeration and netifd WAN setup to complete.
                                                sleep 30
                                        fi
                                elif [ "$usbreset_done" -eq 1 ]; then
                                        [ -f "$watchdog_debug_file" ] && logger -t "$logheader" \
                                                "main: usbreset already invoked for this disconnect event, skipping"
                                fi

                                sleep "$delay_reconnect"
                        fi

                        continue
                fi
        fi

        # Check LTE/QMI/MBIM connection status
        get_lte_status

        # Offline detection
        if [ "$lte_connected" -eq "0" ] || [ "$lte_rc" -ne "0" ]; then

                # Event: lost connection detected by modem (MBIM/QMI).
                # Triggered if:
                #   - uqmi does not report "connected"
                #   - uqmi fails or times out after multiple retries
                # Total worst-case detection time depends on max_retries * timeout_sec.
                logger -t "$logheader" "main: lost connection detected, invoking safe_ifup"

                # Diagnostic: modem status from uqmi/mbim
                [ -f "$watchdog_debug_file" ] && logger -t "$logheader" -- "main: modem status: lte_status=$lte_status lte_rc=$lte_rc lte_connected=$lte_connected"

                # Context: iteration count and delay settings (for tracking reconnection timing)
                [ -f "$watchdog_debug_file" ] && logger -t "$logheader" "main: count=$count delay=$delay delay_reconnect=$delay_reconnect"

                # mark disconnect event
                wan_disconnected=1

                # Execute pre-down script if available
                [ -x "$watchdog_predown_file" ] && "$watchdog_predown_file"

                # Pre-recovery ping log: if the flag file exists, run a single ping
                # and log the result before proceeding with safe_ifup.
                # Observation only: does not affect the recovery decision.
                # Useful to determine whether internet connectivity was already lost
                # before the MBIM disconnection was detected by uqmi, or whether
                # the problem is at the radio layer only.
                # NOTE: adds up to ~3 seconds to recovery time in the worst case
                # (one ping per target in ping_targets, -W 1s timeout each, all failing).
                # Enable with: touch /tmp/watchdog/ping_before_ifup
                # Disable with: rm -f /tmp/watchdog/ping_before_ifup
                if [ -f "$watchdog_directory/ping_before_ifup" ]; then
                        if ping_once; then
                                logger -t "$logheader" "main: pre-recovery ping OK (connectivity present before safe_ifup)"
                        else
                                logger -t "$logheader" "main: pre-recovery ping FAILED (no connectivity before safe_ifup)"
                        fi
                fi

                # Block external AT command scripts during recovery.
                # Must be set before safe_ifup to prevent atcmd from running
                # while the modem is being restarted.
                touch "$atcmd_block_file"

                # call function safe_ifup
                safe_ifup

                # Remove ping_lock stale if the process is no longer alive
                if [ -d "$ping_lock" ] && \
                        ( [ -z "$ping_logger_pid" ] || ! kill -0 "$ping_logger_pid" 2>/dev/null ); then
                        logger -t "$logheader" "main: ping_lock stale detected, removing"
                        rmdir "$ping_lock" 2>/dev/null
                        ping_logger_pid=""
                fi

                # Start ping_logger in background if not already running.
                # ping_logger monitors connectivity and logs when WAN recovers.
                # It will set ping_failed_flag if ping_timeout_sec elapses without
                # a successful ping, triggering escalation on the next iteration.
                if [ ! -d "$ping_lock" ]; then
                        ping_logger &
                        ping_logger_pid=$!
                else
                        [ -f "$watchdog_debug_file" ] && logger -t "$logheader" "main: ping_logger already running, skipping"
                fi

                # Long delay_reconnect: gives WAN time to stabilize and prevents potential race conditions
                sleep "$delay_reconnect"

                # Reset PID reference only if ping_logger has already terminated naturally.
                # In case B (WAN still down after delay_reconnect), ping_logger may still be
                # running up to ping_timeout_sec -- keep PID so cleanup() can kill it.
                # kill -0 does not send any signal, only checks if process is still alive.
                if [ -n "$ping_logger_pid" ] && ! kill -0 "$ping_logger_pid" 2>/dev/null; then
                        ping_logger_pid=""
                fi

                # Reset reconnection counter after WAN restart
                count=0

                continue

        fi

        # Online status
        if [ "$lte_connected" -eq 1 ] && [ "$lte_rc" -eq 0 ]; then

                # Cleanup ping_force_fail_file and ping_failed_flag_file when WAN is online.
                # Prevents a forgotten test file from triggering future false failures.
                if [ -f "$ping_force_fail_file" ] || [ -f "$ping_failed_flag_file" ]; then
                        removed_flags=""
                        if [ -f "$ping_force_fail_file" ]; then
                                rm -f "$ping_force_fail_file"
                                removed_flags="$removed_flags ping_force_fail_file"
                        fi
                        if [ -f "$ping_failed_flag_file" ]; then
                                rm -f "$ping_failed_flag_file"
                                removed_flags="$removed_flags ping_failed_flag_file"
                        fi
                        logger -t "$logheader" "main: WAN online - cleaned watchdog flags:$removed_flags"
                        ping_force_fail_logged=0
                fi

                # Update current IP and check for changes
                # Note: IP change is detected after delay_reconnect seconds (default 120s).
                # The actual change occurred earlier, during the reconnect event.
                # ip_previous holds the last known IP before the disconnect.
                if [ "$wan4_available" -eq 1 ]; then
                        ip_current=$(get_wan_ip)
                        if [ -n "$ip_previous" ] && [ -n "$ip_current" ] && [ "$ip_previous" != "$ip_current" ]; then
                                logger -t "$logheader" "main: IP changed after reconnect: $ip_previous -> $ip_current"
                        fi
                        # Update ip_previous only if ip_current is valid
                        if [ -n "$ip_current" ]; then
                                ip_previous="$ip_current"
                        fi
                fi

                if [ "$wan_disconnected" -eq 1 ]; then
                        # reset disconnect flag, atcmd -C flag, usbreset flag: WAN is back online.
                        wan_disconnected=0
                        atcmd_cfun_done=0
                        atcmd_rc=""
                        usbreset_done=0
                        logger -t "$logheader" "main: flags reset: wan_disconnected=$wan_disconnected atcmd_cfun_done=$atcmd_cfun_done usbreset_done=$usbreset_done"

                        # Optional cleanup of temporary core dumps.
                        # Actual cleanup logic is delegated to /root/cleanup_tmp_core.sh if present.
                        [ -x /root/cleanup_tmp_core.sh ] && timeout --preserve-status -k 2 5 /root/cleanup_tmp_core.sh >/dev/null 2>&1

                        # Remove atcmd_block_file before running postup so that
                        # any AT commands inside the script are not blocked.
                        if [ -f "$atcmd_block_file" ]; then
                                [ -f "$watchdog_debug_file" ] && logger -t "$logheader" "main: removing AT command block file: $atcmd_block_file"
                                rm -f "$atcmd_block_file"
                        fi

                        # Run postup script if available.
                        # Executed once per disconnect event, after all recovery is
                        # complete and atcmd_block_file has been removed.
                        [ -x "$watchdog_postup_file" ] && "$watchdog_postup_file"
                else
                        # Debug log: everything is ok
                        if [ -f "$watchdog_debug_file" ]; then
                                if [ -n "$ip_current" ]; then
                                        logger -t "$logheader" "main: WAN online, everything is ok: count=$count ip=$ip_current"
                                else
                                        logger -t "$logheader" "main: WAN online, everything is ok: count=$count"
                                fi
                        fi
                fi
        fi

        # Safety net: remove atcmd_block_file if still present after recovery.
        # Normally removed inside the wan_disconnected=1 block before postup.
        # This catches edge cases where the block file was left by an incomplete
        # recovery that did not go through the wan_disconnected path.
        # NOTE: all offline/recovery code paths above end with 'continue', so this
        # block is only reached when the modem reports connected (lte_connected=1).
        if [ -f "$atcmd_block_file" ]; then
                [ -f "$watchdog_debug_file" ] && logger -t "$logheader" "main: removing stale AT command block file: $atcmd_block_file"
                rm -f "$atcmd_block_file"
        fi

        # Reset CFUN daily counter if 86400s window has elapsed (uptime-based).
        # Checked here because atcmd may never be called on stable systems,
        # so the reset inside check_cfun_limit() would never trigger.
        if [ -r "/tmp/watchdog/atcmd_cfun_window_start" ]; then
            read -r cfun_win < /tmp/watchdog/atcmd_cfun_window_start
            cfun_now_up=$(get_uptime_sec)
            if [ -n "$cfun_win" ] && [ -n "$cfun_now_up" ] && \
               [ $(( cfun_now_up - cfun_win )) -ge 86400 ] 2>/dev/null; then
                echo "0" > /tmp/watchdog/atcmd_cfun_count
                echo "$cfun_now_up" > /tmp/watchdog/atcmd_cfun_window_start
                logger -t "$logheader" "main: CFUN daily counter reset (window elapsed)"
            fi
        fi

        # Wait before next iteration
        sleep "$delay"

done
